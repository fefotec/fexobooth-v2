#!/bin/bash
# ============================================
# FexoBooth Image Deploy Script
# ============================================
# Spielt das Image auf ein Ziel-Tablet auf.
# Wird automatisch von Clonezilla aufgerufen
# wenn "IMAGE AUFSPIELEN" im Bootmenue gewaehlt wird.
#
# ACHTUNG: Ueberschreibt ALLE Daten auf dem Tablet!
#
# Features:
# - Schreibt alles in ein Log auf FEXODATEN (ueberlebt Reboot)
# - AUTO-IMAGE-SELECTION: Sucht unter mehreren Images auf dem Stick
#   automatisch das groesste das auf die Ziel-Disk passt.
#   So koennen 32 GB und 64 GB Tablets mit demselben Stick geklont
#   werden - einfach beide Images auf FEXODATEN ablegen.
# - Pre-Flight Check VOR Pre-Wipe: bricht ab wenn kein Image passt
#   (Tablet bleibt unveraendert, kein Bricking moeglich)
# - Pre-Wipe der Ziel-Disk (entfernt OEM/Recovery/ebackup-Partitionen)
# - Ignoriert Disk-Size-Check (-icds) fuer minimal abweichende Sektoren
# - Erstellt Partitionen proportional (-k1)
# - Expandiert C-Partition automatisch auf die volle Disk-Groesse
# - Bei Fehler: Log bleibt erhalten, Fehler wird gross angezeigt
# ============================================

# --- Globale Variablen fuer Logging ---
TIMESTAMP=$(date +%Y%m%d-%H%M%S)
LOG_DIR=""
LOG_FILE=""
DEPLOY_STATUS="UNBEKANNT"
ERROR_MESSAGE=""

# --- Frueh: FEXODATEN mounten (fuer Log-Verzeichnis) ---
NTFS_PART=$(blkid -t LABEL=FEXODATEN -o device 2>/dev/null | head -1)
if [ -n "$NTFS_PART" ]; then
    umount /home/partimag 2>/dev/null
    mkdir -p /home/partimag
    mount "$NTFS_PART" /home/partimag 2>/dev/null
fi

# Log-Verzeichnis auf FEXODATEN anlegen
if mountpoint -q /home/partimag; then
    LOG_DIR="/home/partimag/deploy-logs"
    mkdir -p "$LOG_DIR" 2>/dev/null
    LOG_FILE="$LOG_DIR/deploy-${TIMESTAMP}.log"
    touch "$LOG_FILE" 2>/dev/null
fi

# Falls FEXODATEN nicht verfuegbar: Fallback ins RAM
if [ -z "$LOG_FILE" ] || [ ! -w "$LOG_FILE" ]; then
    LOG_FILE="/tmp/deploy-${TIMESTAMP}.log"
    touch "$LOG_FILE"
    echo "WARNUNG: Log nur im RAM - geht bei Reboot verloren!" | tee -a "$LOG_FILE"
fi

# ============================================
# Logging-Helfer
# ============================================
log() {
    echo "$@" | tee -a "$LOG_FILE"
}

log_section() {
    log ""
    log "============================================"
    log "  $*"
    log "============================================"
}

# Trap: Bei jedem Exit Status-Info ans Log anhaengen
cleanup() {
    log ""
    log "============================================"
    log "  DEPLOY STATUS: $DEPLOY_STATUS"
    log "  Zeit: $(date)"
    if [ -n "$ERROR_MESSAGE" ]; then
        log "  Fehler: $ERROR_MESSAGE"
    fi
    log "  Log: $LOG_FILE"
    log "============================================"
    sync
}
trap cleanup EXIT

# ============================================
# Helfer: Image-Sektorzahl aus Metadaten lesen
# ============================================
# WICHTIG: Wir nutzen die BENOETIGTE Groesse, nicht die Disk-Groesse!
#
# Im Image gibt es zwei relevante Groessen:
#   A) last-lba: Ende der Original-Disk (z.B. 122 Mio fuer 64 GB Tablet)
#   B) Ende der LETZTEN Partition: start + size der letzten Partition
#
# Wenn auf dem Master C kleiner als die Disk ist (z.B. Master hat 58 GB
# Disk aber nur 27 GB C durch Shrink), ist die benoetigte Groesse nur
# Ende der letzten Partition + Backup-GPT-Overhead.
#
# Diese benoetigte Groesse ist die richtige Basis fuer den Pre-Flight
# Check - nicht die Original-Disk-Groesse.
#
# Return: Zahl in Sektoren (End-Position der letzten Partition + 2048)
#         oder "" bei Fehler
get_image_sectors() {
    local image_dir="$1"
    local pt_file=$(ls "$image_dir"/*-pt.sf 2>/dev/null | head -1)

    if [ -z "$pt_file" ] || [ ! -f "$pt_file" ]; then
        echo ""
        return
    fi

    # Parse sfdisk-Format:
    # /dev/mmcblk0p1 : start=2048, size=532480, type=...
    # Wir brauchen von der LETZTEN Partition: start + size
    # awk: gehe alle Partition-Zeilen durch, berechne start+size,
    #      behalte das Maximum
    local max_end=$(awk '
        /^\/dev\// {
            start = 0
            size = 0
            for (i = 1; i <= NF; i++) {
                if ($i ~ /^start=/) {
                    sub(/^start=/, "", $i)
                    sub(/,$/, "", $i)
                    start = $i + 0
                }
                if ($i ~ /^size=/) {
                    sub(/^size=/, "", $i)
                    sub(/,$/, "", $i)
                    size = $i + 0
                }
            }
            end = start + size
            if (end > max_end) max_end = end
        }
        END { print max_end }
    ' "$pt_file")

    if [ -z "$max_end" ] || [ "$max_end" = "0" ]; then
        # Fallback: last-lba der Original-Disk (ungenauer)
        local last_lba=$(grep "^last-lba:" "$pt_file" | awk '{print $2}')
        if [ -n "$last_lba" ]; then
            echo $((last_lba + 34))
        else
            echo ""
        fi
        return
    fi

    # +2048 Sektoren Sicherheits-Puffer fuer Backup-GPT + Alignment
    echo $((max_end + 2048))
}

# ============================================
# Helfer: NTFS-Used-Bytes aus Image ermitteln (DREI-STUFEN-FALLBACK)
# ============================================
# Hintergrund: Selbst wenn die Disk-Geometrie im Image groesser ist als das
# Ziel-Tablet, kann der Restore funktionieren, sofern die ECHTEN NTFS-Daten
# ins Ziel passen — Clonezilla schrumpft die Partitionen dann proportional
# via ocs-expand-gpt-pt -icds.
#
# STUFE 1 (genau): partclone.chkimg streamt das XZ-Image und liefert die
#                  exakte Datennutzung. Funktioniert in der Regel.
# STUFE 2 (geschaetzt): XZ-Komprimierungs-Verhaeltnis bei NTFS ~45-50% — wir
#                       nehmen die Summe aller XZ-Image-Teile mal 2.2 als
#                       konservative Obergrenze der echten Datennutzung.
# STUFE 3 (Worst-Case): NTFS-Partitionsgroesse aus dev-fs.list. Worst-Case-
#                       Annahme dass die Partition randvoll ist. Clonezilla
#                       kann mit -icds proportional shrinken, sofern die
#                       Partition selbst ins Ziel passt.

# STUFE 1: Exakte NTFS-Daten via partclone.chkimg
get_image_ntfs_used_bytes_exact() {
    local image_dir="$1"
    # Letzte NTFS-Partition-Datei finden (in Tablet-Image meist mmcblk*p3)
    local ntfs_aa=$(ls "$image_dir"/*.ntfs-ptcl-img.xz.aa 2>/dev/null | sort | tail -1)
    [ -z "$ntfs_aa" ] && return

    local prefix="${ntfs_aa%.aa}"
    local tmp_log="/tmp/ntfs_chkimg_$$.log"

    # Stream alle Parts -> unxz -> partclone.chkimg, dump output ins Log
    ( for img in "${prefix}"*; do cat "$img"; done ) \
        | unxz -c -T 0 2>/dev/null \
        | partclone.chkimg -N -s - > "$tmp_log" 2>&1 || true

    local used_blocks=$(grep "Space in use:" "$tmp_log" | head -1 | sed -E 's/.*= *([0-9]+) *Blocks.*/\1/')
    local block_size=$(grep "Block size:" "$tmp_log" | head -1 | sed -E 's/.*: *([0-9]+) *Byte.*/\1/')

    if [[ "$used_blocks" =~ ^[0-9]+$ ]] && [[ "$block_size" =~ ^[0-9]+$ ]]; then
        rm -f "$tmp_log"
        echo $((used_blocks * block_size))
    else
        # Fehler: Log fuer Diagnose im deploy-logs-Ordner aufheben
        if [ -d "/home/partimag/deploy-logs" ]; then
            local img_basename=$(basename "$image_dir")
            cp "$tmp_log" "/home/partimag/deploy-logs/chkimg-failure-${img_basename}-$(date +%H%M%S).log" 2>/dev/null || true
        fi
        rm -f "$tmp_log"
    fi
}

# STUFE 2: Geschaetzte NTFS-Daten aus XZ-Image-Groesse (Faktor 2.2)
get_image_ntfs_used_bytes_estimated() {
    local image_dir="$1"
    # Summe aller XZ-Teile der NTFS-Partition (.xz.aa, .xz.ab, ...)
    local ntfs_aa=$(ls "$image_dir"/*.ntfs-ptcl-img.xz.aa 2>/dev/null | sort | tail -1)
    [ -z "$ntfs_aa" ] && return

    local prefix="${ntfs_aa%.aa}"
    local total=0
    for img in "${prefix}"*; do
        [ -f "$img" ] || continue
        local sz=$(stat -c '%s' "$img" 2>/dev/null)
        [[ "$sz" =~ ^[0-9]+$ ]] && total=$((total + sz))
    done

    if [ "$total" -gt 0 ]; then
        # Faktor 2.2 = konservative obere Grenze (NTFS-XZ ~45-50% Ratio)
        echo $((total * 22 / 10))
    fi
}

# STUFE 3: NTFS-Partitionsgroesse aus dev-fs.list (Worst-Case)
get_image_ntfs_partition_bytes() {
    local image_dir="$1"
    local list_file="$image_dir/dev-fs.list"
    [ ! -f "$list_file" ] && return

    # Letzte NTFS-Zeile, dritte Spalte ist Groesse (z.B. "27.9G")
    local size=$(grep -i ' ntfs ' "$list_file" | awk '{print $3}' | tail -1)
    [ -z "$size" ] && return

    # "27.9G" -> Bytes via awk (unterstuetzt Float)
    case "$size" in
        *G|*g)
            local num="${size%[Gg]}"
            awk -v n="$num" 'BEGIN { printf "%.0f\n", n * 1024 * 1024 * 1024 }'
            ;;
        *M|*m)
            local num="${size%[Mm]}"
            awk -v n="$num" 'BEGIN { printf "%.0f\n", n * 1024 * 1024 }'
            ;;
    esac
}

# Kombinierte Funktion: probiert alle drei Stufen, gibt "<bytes>|<methode>" zurueck
# oder leeren String wenn alle drei fehlschlagen.
get_image_ntfs_used_bytes() {
    local image_dir="$1"

    # Stufe 1: exakt
    local exact=$(get_image_ntfs_used_bytes_exact "$image_dir")
    if [[ "$exact" =~ ^[0-9]+$ ]] && [ "$exact" -gt 0 ]; then
        echo "${exact}|exakt (partclone.chkimg)"
        return
    fi

    # Stufe 2: geschaetzt aus XZ-Groesse
    local estimated=$(get_image_ntfs_used_bytes_estimated "$image_dir")
    if [[ "$estimated" =~ ^[0-9]+$ ]] && [ "$estimated" -gt 0 ]; then
        echo "${estimated}|geschaetzt (XZ-Groesse * 2.2)"
        return
    fi

    # Stufe 3: NTFS-Partitionsgroesse (Worst-Case)
    local partition=$(get_image_ntfs_partition_bytes "$image_dir")
    if [[ "$partition" =~ ^[0-9]+$ ]] && [ "$partition" -gt 0 ]; then
        echo "${partition}|Worst-Case (NTFS-Partitionsgroesse)"
        return
    fi

    # Alle drei fehlgeschlagen
    return
}

# ============================================
# START
# ============================================
log_section "FexoBooth - IMAGE AUFSPIELEN"
log "Zeit: $(date)"
log "Log-Datei: $LOG_FILE"
log ""

# --- FEXODATEN Status ---
if mountpoint -q /home/partimag; then
    log "[OK] FEXODATEN gemountet nach /home/partimag ($NTFS_PART)"
else
    log "WARNUNG: FEXODATEN konnte nicht gemountet werden!"
fi
log ""

# ============================================
# USB-Stick ermitteln (muessen wir kennen um ihn nicht als Ziel zu nehmen)
# ============================================
USB_DISK=""
for mnt in /run/live/medium /home/partimag; do
    DEV=$(mount | grep " $mnt " | awk '{print $1}')
    if [ -n "$DEV" ]; then
        DISK=$(lsblk -no PKNAME "$DEV" 2>/dev/null | head -1)
        if [ -n "$DISK" ]; then
            USB_DISK="$DISK"
        fi
    fi
done
log "USB-Stick erkannt als: /dev/$USB_DISK"
log ""

# ============================================
# Ziel-Disk ermitteln
# ============================================
TARGET_DISK=""
for dev in /dev/mmcblk[0-9] /dev/mmcblk[0-9][0-9] /dev/nvme[0-9]n[0-9] /dev/sd[a-z]; do
    if [ -b "$dev" ]; then
        DEVNAME=$(basename "$dev")
        if [ "$DEVNAME" = "$USB_DISK" ]; then
            log "Ueberspringe USB-Stick: /dev/$DEVNAME"
            continue
        fi
        case "$DEVNAME" in
            mmcblk*boot*) continue ;;
        esac
        TYPE=$(lsblk -no TYPE "$dev" 2>/dev/null | head -1)
        if [ "$TYPE" != "disk" ]; then
            continue
        fi
        TARGET_DISK="$DEVNAME"
        log "Ziel gefunden: /dev/$TARGET_DISK"
        break
    fi
done

if [ -z "$TARGET_DISK" ]; then
    DEPLOY_STATUS="FEHLER"
    ERROR_MESSAGE="Keine Ziel-Festplatte gefunden"
    log ""
    log "FEHLER: Keine Ziel-Festplatte gefunden!"
    log "USB-Stick war: /dev/$USB_DISK"
    log ""
    log "Alle erkannten Block-Geraete:"
    lsblk -d -o NAME,SIZE,TYPE,MODEL,TRAN 2>&1 | tee -a "$LOG_FILE"
    echo ""
    echo "############################################"
    echo "#                                          #"
    echo "#   FEHLER - siehe Log auf USB-Stick!     #"
    echo "#   Pfad: FEXODATEN/deploy-logs/          #"
    echo "#                                          #"
    echo "############################################"
    echo ""
    read -p "Druecke Enter zum Neustarten..." dummy
    reboot
    exit 1
fi

log "Ziel-Disk: /dev/$TARGET_DISK"
log ""

# Disk-Info fuer Log dokumentieren
log "Ziel-Disk Details (VOR Pre-Wipe):"
lsblk -o NAME,SIZE,TYPE,FSTYPE,LABEL /dev/$TARGET_DISK 2>&1 | tee -a "$LOG_FILE"
log ""
TARGET_SECTORS=$(blockdev --getsz /dev/$TARGET_DISK 2>/dev/null)
TARGET_BYTES=$(blockdev --getsize64 /dev/$TARGET_DISK 2>/dev/null)
TARGET_GB=$((TARGET_SECTORS * 512 / 1024 / 1024 / 1024))
log "Sektoren (Ziel-Disk):   $TARGET_SECTORS"
log "Groesse in Bytes:       $TARGET_BYTES"
log "Groesse in GB:          ~${TARGET_GB} GB"
log ""

# ============================================
# AUTO-IMAGE-SELECTION
# ============================================
# Scannt alle Images auf FEXODATEN, ermittelt deren Original-
# Disk-Groesse und waehlt automatisch das GROESSTE das auf die
# Ziel-Disk passt (mit 5% Toleranz).
#
# Beispiel: Ziel-Tablet hat 31 GB, auf dem Stick liegen:
#   - fexobooth-image-20260420 (62 GB) -> zu gross, uebersprungen
#   - fexobooth-image-32gb-20260422 (30 GB) -> passt! wird gewaehlt
log_section "AUTO-IMAGE-SELECTION: Passendes Image fuer ~${TARGET_GB} GB Tablet suchen"

# Alle Image-Ordner scannen
# Wir erstellen eine Liste: "sektoren|name" pro gefundenem Image
ALL_IMAGES=""
IMAGE_COUNT=0

for dir in /home/partimag/fexobooth-image-*; do
    if [ -d "$dir" ]; then
        IMAGE_COUNT=$((IMAGE_COUNT + 1))
        local_name=$(basename "$dir")
        local_sectors=$(get_image_sectors "$dir")

        if [ -n "$local_sectors" ]; then
            local_gb=$((local_sectors * 512 / 1024 / 1024 / 1024))
            log "  [$IMAGE_COUNT] $local_name -> ${local_sectors} Sektoren (~${local_gb} GB)"
            ALL_IMAGES="${ALL_IMAGES}${local_sectors}|${dir}|${local_name}
"
        else
            log "  [$IMAGE_COUNT] $local_name -> WARNUNG: Sektorzahl nicht ermittelbar (uebersprungen)"
        fi
    fi
done

if [ "$IMAGE_COUNT" -eq 0 ]; then
    DEPLOY_STATUS="FEHLER"
    ERROR_MESSAGE="Kein FexoBooth-Image auf dem USB-Stick gefunden"
    log ""
    log "FEHLER: Kein FexoBooth-Image auf dem USB-Stick gefunden!"
    log ""
    log "Inhalt von /home/partimag/:"
    ls -la /home/partimag/ 2>&1 | tee -a "$LOG_FILE"
    echo ""
    echo "############################################"
    echo "#                                          #"
    echo "#   KEIN IMAGE GEFUNDEN!                   #"
    echo "#                                          #"
    echo "#   Bitte zuerst ein Image erstellen       #"
    echo "#   (Capture-Modus).                       #"
    echo "#                                          #"
    echo "############################################"
    echo ""
    read -p "Druecke Enter zum Neustarten..." dummy
    reboot
    exit 1
fi

log ""

# Passendes Image waehlen: 5% Toleranz, groesstes das reinpasst
# Algorithmus:
#   1. Filter: Images mit Sektorzahl <= 105% der Ziel-Sektorzahl
#      (105% weil bei kleinen Differenzen -icds das regelt)
#   2. Sortiere absteigend nach Sektorzahl
#   3. Nimm das erste (groesste)
MAX_ACCEPTABLE=$((TARGET_SECTORS * 105 / 100))

IMAGE_DIR=""
IMAGE_NAME=""
IMAGE_SECTORS=""

# sort -rn sortiert numerisch absteigend, awk filtert und picked first
SELECTED=$(echo "$ALL_IMAGES" | grep -v "^$" | awk -F'|' -v max="$MAX_ACCEPTABLE" '$1 <= max {print $0}' | sort -t'|' -k1 -rn | head -1)

if [ -n "$SELECTED" ]; then
    IMAGE_SECTORS=$(echo "$SELECTED" | awk -F'|' '{print $1}')
    IMAGE_DIR=$(echo "$SELECTED" | awk -F'|' '{print $2}')
    IMAGE_NAME=$(echo "$SELECTED" | awk -F'|' '{print $3}')
    IMAGE_GB=$((IMAGE_SECTORS * 512 / 1024 / 1024 / 1024))
    log "[OK] Gewaehltes Image: $IMAGE_NAME (~${IMAGE_GB} GB)"
else
    # ============================================
    # Smart-Fallback: NTFS-Used-Check
    # ============================================
    # Direkter Disk-Groessen-Vergleich hat versagt — alle Images haben
    # eine groessere Disk-Geometrie als das Ziel. Aber: Wenn die ECHTEN
    # NTFS-Daten ins Ziel passen, kann Clonezilla beim Restore
    # proportional schrumpfen (ocs-expand-gpt-pt -icds).
    #
    # Wir pruefen pro Image die echte Datennutzung via partclone.chkimg
    # und nehmen das KLEINSTE Image, dessen NTFS-Daten ins Ziel passen.
    log ""
    log "Smart-Check: kein Image direkt passend, pruefe ECHTE NTFS-Datennutzung..."
    log ""

    # Bytes-Reservierungen fuer EFI + MSR + GPT-Overhead + Sicherheits-Buffer
    STATIC_RESERVE_BYTES=$((400 * 1024 * 1024))      # ~400 MB fuer EFI + MSR
    SAFETY_BUFFER_BYTES=$((1024 * 1024 * 1024))      # 1 GB Sicherheits-Buffer
    AVAILABLE_BYTES=$((TARGET_BYTES - STATIC_RESERVE_BYTES - SAFETY_BUFFER_BYTES))
    AVAILABLE_GB=$((AVAILABLE_BYTES / 1024 / 1024 / 1024))
    log "Verfuegbar im Ziel-Tablet (NTFS): ~${AVAILABLE_GB} GB (nach EFI/MSR/Buffer)"
    log ""

    # Iteriere von kleinster zu groesster Disk-Groesse, nimm erstes
    # passendes Image. Ergebnis in tmp-Datei weil while in Pipe Subshell laeuft.
    SMART_TMP="/tmp/smart_select_$$.txt"
    > "$SMART_TMP"
    echo "$ALL_IMAGES" | grep -v "^$" | sort -t'|' -k1 -n > "$SMART_TMP.list"

    while IFS='|' read -r line_sectors line_dir line_name; do
        [ -z "$line_sectors" ] && continue
        log "Pruefe NTFS-Datengroesse von '$line_name' (kann 30-60 Sek dauern)..."

        # Drei-Stufen-Fallback: exakt -> XZ-geschaetzt -> Partitionsgroesse
        result=$(get_image_ntfs_used_bytes "$line_dir")

        if [ -z "$result" ]; then
            log "  -> Alle drei Mess-Methoden fehlgeschlagen, uebersprungen"
            log "     (chkimg-Failure-Log liegt in /home/partimag/deploy-logs/)"
            continue
        fi

        ntfs_bytes=$(echo "$result" | cut -d'|' -f1)
        method=$(echo "$result" | cut -d'|' -f2)
        ntfs_gb=$((ntfs_bytes / 1024 / 1024 / 1024))
        log "  NTFS-Daten in Image: ~${ntfs_gb} GB (Methode: ${method})"

        if [ "$ntfs_bytes" -lt "$AVAILABLE_BYTES" ]; then
            log "  -> [OK] Daten passen ins Ziel — wird gewaehlt (Clonezilla shrinkt proportional)"
            echo "$line_sectors|$line_dir|$line_name" > "$SMART_TMP"
            break
        else
            log "  -> [ZU GROSS] Daten passen nicht ins ${TARGET_GB} GB Tablet"
        fi
    done < "$SMART_TMP.list"

    rm -f "$SMART_TMP.list"

    if [ -s "$SMART_TMP" ]; then
        SMART_SELECTED=$(cat "$SMART_TMP")
        rm -f "$SMART_TMP"

        IMAGE_SECTORS=$(echo "$SMART_SELECTED" | awk -F'|' '{print $1}')
        IMAGE_DIR=$(echo "$SMART_SELECTED" | awk -F'|' '{print $2}')
        IMAGE_NAME=$(echo "$SMART_SELECTED" | awk -F'|' '{print $3}')
        IMAGE_GB=$((IMAGE_SECTORS * 512 / 1024 / 1024 / 1024))

        log ""
        log "############################################"
        log "  Smart-Select: $IMAGE_NAME"
        log "  Disk-Geometrie im Image: ~${IMAGE_GB} GB"
        log "  Ziel-Disk:               ~${TARGET_GB} GB"
        log "  NTFS-Daten passen — Clonezilla wird proportional shrinken."
        log "############################################"
        log ""

        # Spruenge zur Pre-Wipe-Phase, ueberspringe den Abbruch
        # (kein zusaetzliches goto noetig — der else-Block faellt durch)
    else
        rm -f "$SMART_TMP"
        # Auch Smart-Check versagt -> wirklich abbrechen
        SMALLEST=$(echo "$ALL_IMAGES" | grep -v "^$" | sort -t'|' -k1 -n | head -1)
        SMALLEST_SECTORS=$(echo "$SMALLEST" | awk -F'|' '{print $1}')
        SMALLEST_GB=$((SMALLEST_SECTORS * 512 / 1024 / 1024 / 1024))

        DEPLOY_STATUS="ABGEBROCHEN_VOR_WIPE"
        ERROR_MESSAGE="Kein Image passt auf ${TARGET_GB}GB Tablet (kleinstes Image: ${SMALLEST_GB}GB)"

        log ""
        log "############################################"
        log "  ABBRUCH: KEIN PASSENDES IMAGE!"
        log "############################################"
        log ""
        log "  Ziel-Tablet hat ~${TARGET_GB} GB"
        log "  Kleinstes Image auf dem Stick: ~${SMALLEST_GB} GB"
        log "  Auch Smart-Check (echte NTFS-Daten): keine Daten passen ins Ziel."
        log ""
        log "  TABLET BLEIBT UNVERAENDERT - kein Pre-Wipe!"
        log ""
        log "  LOESUNG: Image fuer ${TARGET_GB} GB Tablets erstellen"
        log "    - Referenz-Tablet mit <= ${TARGET_GB} GB verwenden"
        log "    - Oder: C auf Referenz-Tablet auf ~$((TARGET_GB - 3)) GB schrumpfen"
        log "    - Dann neu capturen (Capture-Modus)"
        log "    - Image auf diesen Stick dazulegen, dann neu deployen"
        log ""

        echo ""
        echo "############################################"
        echo "#                                          #"
        echo "#   ABBRUCH: KEIN PASSENDES IMAGE!         #"
        echo "#                                          #"
        echo "#   Tablet:          ~${TARGET_GB} GB"
        echo "#   Kleinstes Image: ~${SMALLEST_GB} GB"
        echo "#                                          #"
        echo "#   Tablet bleibt UNVERAENDERT.            #"
        echo "#   (Pre-Wipe wurde NICHT ausgefuehrt!)    #"
        echo "#                                          #"
        echo "#   Auch ECHTE NTFS-Datengroesse zu gross. #"
        echo "#   Fuer ${TARGET_GB} GB Tablets muss ein eigenes"
        echo "#   (kleineres) Image erstellt werden.     #"
        echo "#                                          #"
        echo "############################################"
        echo ""
        read -p "Druecke Enter zum Neustarten..." dummy
        reboot
        exit 1
    fi
fi

log ""

# ============================================
# Pre-Wipe: Partitionstabelle auf Ziel-Disk entfernen
# ============================================
# Entfernt OEM-/Recovery-/ebackup-Partitionen, GPT-Schutzstrukturen,
# alte Boot-Signaturen. ocs-sr restoredisk ueberschreibt danach
# eine "jungfraeuliche" Disk, das ist deutlich zuverlaessiger.
log_section "PRE-WIPE: Partitionstabelle auf /dev/$TARGET_DISK entfernen"

# Alle moeglichen Partitionen des Ziels un-mounten (safety)
for part in $(lsblk -lno NAME /dev/$TARGET_DISK 2>/dev/null | tail -n +2); do
    umount "/dev/$part" 2>/dev/null
done

# sgdisk --zap-all: loescht GPT + MBR + Backup-GPT
if command -v sgdisk >/dev/null 2>&1; then
    log "Fuehre aus: sgdisk --zap-all /dev/$TARGET_DISK"
    sgdisk --zap-all /dev/$TARGET_DISK 2>&1 | tee -a "$LOG_FILE"
else
    log "sgdisk nicht verfuegbar - ueberspringe GPT-Wipe"
fi

# wipefs -a: loescht verbleibende Filesystem-Signaturen
if command -v wipefs >/dev/null 2>&1; then
    log "Fuehre aus: wipefs -a /dev/$TARGET_DISK"
    wipefs -a /dev/$TARGET_DISK 2>&1 | tee -a "$LOG_FILE"
fi

# Sicherheits-Puffer: erste 10 MB mit Nullen ueberschreiben
log "Fuehre aus: dd if=/dev/zero of=/dev/$TARGET_DISK bs=1M count=10"
dd if=/dev/zero of=/dev/$TARGET_DISK bs=1M count=10 conv=fsync 2>&1 | tee -a "$LOG_FILE"

# Kernel soll neue (leere) Partitionstabelle einlesen
partprobe /dev/$TARGET_DISK 2>&1 | tee -a "$LOG_FILE" || true
sleep 2

log ""
log "[OK] Pre-Wipe abgeschlossen"
log ""
log "Ziel-Disk Details (NACH Pre-Wipe):"
lsblk -o NAME,SIZE,TYPE,FSTYPE,LABEL /dev/$TARGET_DISK 2>&1 | tee -a "$LOG_FILE"
log ""

# ============================================
# Clonezilla restoredisk ausfuehren
# ============================================
# Flags:
#   -e1 auto  = Partitionstabelle aus Image uebernehmen (1:1)
#   -icds     = Ignore Check Disk Size: akzeptiert Ziel-Disk die
#               kleiner ist als die Original-Image-Disk.
#               Wir haben bereits im Pre-Flight geprueft dass die
#               tatsaechlich benoetigte Groesse (Ende der letzten
#               Partition) in die Ziel-Disk passt.
#   -batch    = Keine Bestaetigung
#   -p true   = ocs-sr beenden ohne eigenen Dialog
#
# WICHTIG: KEIN -k1 mehr! Das hat frueher die Partitionen
# proportional geschrumpft (z.B. 27 GB C auf 13 GB), was dann
# die NTFS-Daten nicht mehr reinpassen liess und zum
# "target seek ERROR" fuehrte. Stattdessen: Original-
# Partitionstabelle 1:1 uebernehmen, Post-Expand macht C auf
# groesseren Ziel-Disks danach voll.
log_section "CLONEZILLA RESTORE: $IMAGE_NAME auf /dev/$TARGET_DISK"
log "Dauer: ca. 15-20 Minuten"
log ""

/usr/sbin/ocs-sr \
    -e1 auto \
    -icds \
    -batch \
    -p true \
    restoredisk "$IMAGE_NAME" "$TARGET_DISK" 2>&1 | tee -a "$LOG_FILE"

OCS_EXIT=${PIPESTATUS[0]}
log ""
log "ocs-sr Exit-Code: $OCS_EXIT"
log ""

if [ "$OCS_EXIT" -ne 0 ]; then
    DEPLOY_STATUS="FEHLER"
    ERROR_MESSAGE="ocs-sr restoredisk schlug fehl (Exit-Code $OCS_EXIT)"
    log "FEHLER: ocs-sr restoredisk ist fehlgeschlagen!"
    echo ""
    echo "############################################"
    echo "#                                          #"
    echo "#   FEHLER beim Image aufspielen!          #"
    echo "#                                          #"
    echo "#   Log auf USB-Stick unter:               #"
    echo "#   FEXODATEN/deploy-logs/                 #"
    echo "#                                          #"
    echo "#   Datei: deploy-${TIMESTAMP}.log         "
    echo "#                                          #"
    echo "############################################"
    echo ""
    read -p "Druecke Enter zum Neustarten..." dummy
    reboot
    exit 1
fi

log "[OK] Image erfolgreich aufgespielt"
log ""

# ============================================
# Post-Expand: C-Partition auf volle Disk-Groesse strecken
# ============================================
log_section "POST-EXPAND: C-Partition auf volle Groesse strecken"

partprobe /dev/$TARGET_DISK 2>&1 | tee -a "$LOG_FILE" || true
sleep 2

log "Partitionstabelle nach Restore:"
parted /dev/$TARGET_DISK print 2>&1 | tee -a "$LOG_FILE" || true
log ""

# Groesste NTFS-Partition finden (das ist C:)
C_PART=$(lsblk -bln -o NAME,SIZE,FSTYPE /dev/$TARGET_DISK 2>/dev/null | \
         awk '$3=="ntfs" {print $2" "$1}' | \
         sort -rn | head -1 | awk '{print $2}')

if [ -z "$C_PART" ]; then
    log "WARNUNG: Keine NTFS-Partition gefunden - Post-Expand uebersprungen"
    log "(Bild wurde aufgespielt, Windows sollte aber trotzdem booten)"
else
    log "Groesste NTFS-Partition: /dev/$C_PART"
    PART_NUM=$(echo "$C_PART" | grep -oE '[0-9]+$')
    log "Partition-Nummer: $PART_NUM"

    if [ -n "$PART_NUM" ]; then
        log "parted: resizepart $PART_NUM 100%"
        parted --script /dev/$TARGET_DISK resizepart $PART_NUM 100% 2>&1 | tee -a "$LOG_FILE"
        PARTED_EXIT=${PIPESTATUS[0]}

        partprobe /dev/$TARGET_DISK 2>&1 | tee -a "$LOG_FILE" || true
        sleep 2

        if [ "$PARTED_EXIT" -eq 0 ]; then
            log "ntfsresize: Dateisystem auf volle Partition ausdehnen"
            ntfsresize --force --force --no-progress-bar /dev/$C_PART 2>&1 | tee -a "$LOG_FILE"
            NTFS_EXIT=${PIPESTATUS[0]}

            if [ "$NTFS_EXIT" -eq 0 ]; then
                log "[OK] C-Partition erfolgreich auf volle Groesse erweitert"
            else
                log "WARNUNG: ntfsresize Exit-Code $NTFS_EXIT"
                log "(Windows repariert sich beim ersten Boot meist selbst)"
            fi
        else
            log "WARNUNG: parted resizepart schlug fehl (Exit $PARTED_EXIT)"
        fi
    fi
fi

log ""
log "Finale Partitionstabelle:"
lsblk -o NAME,SIZE,TYPE,FSTYPE,LABEL /dev/$TARGET_DISK 2>&1 | tee -a "$LOG_FILE"
log ""

# ============================================
# ERFOLG
# ============================================
DEPLOY_STATUS="ERFOLG"
log_section "FERTIG! Tablet wird neu gestartet..."
log ""
echo ""
echo "############################################"
echo "#                                          #"
echo "#   IMAGE ERFOLGREICH AUFGESPIELT!         #"
echo "#                                          #"
echo "#   Image: $IMAGE_NAME"
echo "#                                          #"
echo "#   Tablet startet in 5 Sekunden neu.      #"
echo "#                                          #"
echo "############################################"
echo ""
sleep 5
reboot

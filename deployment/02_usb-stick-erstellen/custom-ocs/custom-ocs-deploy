#!/bin/bash
# ============================================
# FexoBooth Image Deploy Script
# ============================================
# Spielt das Image auf ein Ziel-Tablet auf.
# Wird automatisch von Clonezilla aufgerufen
# wenn "IMAGE AUFSPIELEN" im Bootmenue gewaehlt wird.
#
# ACHTUNG: Ueberschreibt ALLE Daten auf dem Tablet!
# ============================================

echo ""
echo "============================================"
echo "  FexoBooth - IMAGE AUFSPIELEN"
echo "============================================"
echo ""

# --- FEXODATEN (NTFS) mounten ---
# Das Image liegt auf der NTFS-Datenpartition,
# nicht auf der FAT32-Bootpartition.
NTFS_PART=$(blkid -t LABEL=FEXODATEN -o device 2>/dev/null | head -1)
if [ -n "$NTFS_PART" ]; then
    echo "FEXODATEN gefunden: $NTFS_PART"
    umount /home/partimag 2>/dev/null
    mkdir -p /home/partimag
    mount $NTFS_PART /home/partimag
    if [ $? -eq 0 ]; then
        echo "[OK] FEXODATEN gemountet nach /home/partimag"
    else
        echo "WARNUNG: FEXODATEN konnte nicht gemountet werden!"
    fi
else
    echo "FEXODATEN nicht gefunden, nutze Standard-Speicher (FEXOBOOT)"
fi
echo ""

# Image auf dem USB-Stick finden
IMAGE_DIR=""
IMAGE_NAME=""

for dir in /home/partimag/fexobooth-image-*; do
    if [ -d "$dir" ]; then
        IMAGE_DIR="$dir"
        IMAGE_NAME=$(basename "$dir")
    fi
done

if [ -z "$IMAGE_NAME" ]; then
    echo "FEHLER: Kein FexoBooth-Image auf dem USB-Stick gefunden!"
    echo ""
    echo "Inhalt von /home/partimag/:"
    ls -la /home/partimag/ 2>/dev/null || echo "(leer)"
    echo ""
    echo "Bitte zuerst ein Image erstellen (Capture-Modus)."
    echo ""
    read -p "Druecke Enter zum Neustarten..." dummy
    reboot
fi

echo "Image gefunden: $IMAGE_NAME"
echo ""

# Auto-detect Ziel-Disk
# USB-Stick ermitteln (wo Clonezilla + Image drauf sind)
USB_DISK=""
for mnt in /run/live/medium /home/partimag; do
    DEV=$(mount | grep " $mnt " | awk '{print $1}')
    if [ -n "$DEV" ]; then
        # Partition zu Disk aufloesen (sda1->sda, nvme0n1p1->nvme0n1)
        DISK=$(lsblk -no PKNAME "$DEV" 2>/dev/null | head -1)
        if [ -n "$DISK" ]; then
            USB_DISK="$DISK"
        fi
    fi
done
echo "USB-Stick erkannt als: /dev/$USB_DISK"

# Alle echten Disks durchsuchen (USB-Stick ausschliessen)
TARGET_DISK=""
for dev in /dev/mmcblk[0-9] /dev/mmcblk[0-9][0-9] /dev/nvme[0-9]n[0-9] /dev/sd[a-z]; do
    if [ -b "$dev" ]; then
        DEVNAME=$(basename "$dev")
        # USB-Stick ueberspringen
        if [ "$DEVNAME" = "$USB_DISK" ]; then
            echo "Ueberspringe USB-Stick: /dev/$DEVNAME"
            continue
        fi
        # mmcblk0bootX sind keine echten Disks
        case "$DEVNAME" in
            mmcblk*boot*) continue ;;
        esac
        # Loop-Devices ueberspringen
        TYPE=$(lsblk -no TYPE "$dev" 2>/dev/null | head -1)
        if [ "$TYPE" != "disk" ]; then
            continue
        fi
        TARGET_DISK="$DEVNAME"
        echo "Ziel gefunden: /dev/$TARGET_DISK"
        break
    fi
done

if [ -z "$TARGET_DISK" ]; then
    echo ""
    echo "FEHLER: Keine Ziel-Festplatte gefunden!"
    echo ""
    echo "USB-Stick war: /dev/$USB_DISK"
    echo ""
    echo "Alle erkannten Block-Geraete:"
    lsblk -d -o NAME,SIZE,TYPE,MODEL,TRAN
    echo ""
    echo "Alle Mount-Punkte:"
    mount | grep -E "^/dev/"
    echo ""
    read -p "Druecke Enter zum Neustarten..." dummy
    reboot
fi

echo "Ziel-Disk: /dev/$TARGET_DISK"
echo ""

# Disk-Info anzeigen
echo "Ziel-Disk Informationen:"
lsblk -o NAME,SIZE,TYPE,FSTYPE,LABEL /dev/$TARGET_DISK
echo ""

echo "============================================"
echo "  ACHTUNG: ALLE Daten auf /dev/$TARGET_DISK"
echo "  werden UNWIDERRUFLICH ueberschrieben!"
echo ""
echo "  Image: $IMAGE_NAME"
echo "  Dauer: ca. 15-20 Minuten"
echo "============================================"
echo ""

# Clonezilla restoredisk ausfuehren
# -e1 auto  = Partitionstabelle aus Image uebernehmen
# -c        = Bestaetigung anfordern (Sicherheit!)
# -p reboot = Nach Abschluss neustarten
/usr/sbin/ocs-sr \
    -e1 auto \
    -c \
    -p reboot \
    restoredisk "$IMAGE_NAME" "$TARGET_DISK"

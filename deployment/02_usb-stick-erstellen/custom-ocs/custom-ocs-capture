#!/bin/bash
# ============================================
# FexoBooth Image Capture Script
# ============================================
# Erstellt ein Image vom Referenz-Tablet.
# Wird automatisch von Clonezilla aufgerufen
# wenn "IMAGE ERSTELLEN" im Bootmenue gewaehlt wird.
#
# Unterstuetzt: eMMC, NVMe, SATA (beliebiges Lenovo-Modell)
#
# Features:
# - Schreibt alles in ein Log auf FEXODATEN (ueberlebt Reboot)
# - Bei Fehler: Log bleibt erhalten, Fehler wird gross angezeigt
# ============================================

# --- Globale Variablen fuer Logging ---
TIMESTAMP=$(date +%Y%m%d-%H%M%S)
LOG_DIR=""
LOG_FILE=""
CAPTURE_STATUS="UNBEKANNT"
ERROR_MESSAGE=""

# --- Frueh: FEXODATEN mounten (fuer Log-Verzeichnis + Image-Speicher) ---
NTFS_PART=$(blkid -t LABEL=FEXODATEN -o device 2>/dev/null | head -1)
if [ -n "$NTFS_PART" ]; then
    umount /home/partimag 2>/dev/null
    mkdir -p /home/partimag
    mount "$NTFS_PART" /home/partimag 2>/dev/null
fi

# Log-Verzeichnis auf FEXODATEN anlegen (selbe Logik wie Deploy)
if mountpoint -q /home/partimag; then
    LOG_DIR="/home/partimag/capture-logs"
    mkdir -p "$LOG_DIR" 2>/dev/null
    LOG_FILE="$LOG_DIR/capture-${TIMESTAMP}.log"
    touch "$LOG_FILE" 2>/dev/null
fi

if [ -z "$LOG_FILE" ] || [ ! -w "$LOG_FILE" ]; then
    LOG_FILE="/tmp/capture-${TIMESTAMP}.log"
    touch "$LOG_FILE"
    echo "WARNUNG: Log nur im RAM - geht bei Reboot verloren!" | tee -a "$LOG_FILE"
fi

# ============================================
# Logging-Helfer
# ============================================
log() {
    echo "$@" | tee -a "$LOG_FILE"
}

log_section() {
    log ""
    log "============================================"
    log "  $*"
    log "============================================"
}

# Trap: Bei Exit Status-Info ans Log
cleanup() {
    log ""
    log "============================================"
    log "  CAPTURE STATUS: $CAPTURE_STATUS"
    log "  Zeit: $(date)"
    if [ -n "$ERROR_MESSAGE" ]; then
        log "  Fehler: $ERROR_MESSAGE"
    fi
    log "  Log: $LOG_FILE"
    log "============================================"
    sync
}
trap cleanup EXIT

# ============================================
# START
# ============================================
log_section "FexoBooth - IMAGE ERSTELLEN"
log "Zeit: $(date)"
log "Log-Datei: $LOG_FILE"
log ""

# --- FEXODATEN Status ausgeben ---
if mountpoint -q /home/partimag; then
    log "[OK] FEXODATEN gemountet nach /home/partimag ($NTFS_PART)"
    log "     Image wird auf FEXODATEN gespeichert"
else
    log "WARNUNG: FEXODATEN konnte nicht gemountet werden, nutze Standard-Speicher"
fi
log ""

# ============================================
# Auto-detect Quell-Disk
# ============================================
USB_DISK=""
for mnt in /run/live/medium /home/partimag; do
    DEV=$(mount | grep " $mnt " | awk '{print $1}')
    if [ -n "$DEV" ]; then
        DISK=$(lsblk -no PKNAME "$DEV" 2>/dev/null | head -1)
        if [ -n "$DISK" ]; then
            USB_DISK="$DISK"
        fi
    fi
done
log "USB-Stick erkannt als: /dev/$USB_DISK"

TARGET_DISK=""
for dev in /dev/mmcblk[0-9] /dev/mmcblk[0-9][0-9] /dev/nvme[0-9]n[0-9] /dev/sd[a-z]; do
    if [ -b "$dev" ]; then
        DEVNAME=$(basename "$dev")
        if [ "$DEVNAME" = "$USB_DISK" ]; then
            log "Ueberspringe USB-Stick: /dev/$DEVNAME"
            continue
        fi
        case "$DEVNAME" in
            mmcblk*boot*) continue ;;
        esac
        TYPE=$(lsblk -no TYPE "$dev" 2>/dev/null | head -1)
        if [ "$TYPE" != "disk" ]; then
            continue
        fi
        TARGET_DISK="$DEVNAME"
        log "Quelle gefunden: /dev/$TARGET_DISK"
        break
    fi
done

if [ -z "$TARGET_DISK" ]; then
    CAPTURE_STATUS="FEHLER"
    ERROR_MESSAGE="Keine Festplatte/eMMC gefunden"
    log ""
    log "FEHLER: Keine Festplatte/eMMC gefunden!"
    log ""
    log "USB-Stick war: /dev/$USB_DISK"
    log ""
    log "Alle erkannten Block-Geraete:"
    lsblk -d -o NAME,SIZE,TYPE,MODEL,TRAN 2>&1 | tee -a "$LOG_FILE"
    log ""
    log "Alle Mount-Punkte:"
    mount | grep -E "^/dev/" 2>&1 | tee -a "$LOG_FILE"
    log ""
    echo "############################################"
    echo "#                                          #"
    echo "#   FEHLER - siehe Log auf USB-Stick!     #"
    echo "#   Pfad: FEXODATEN/capture-logs/         #"
    echo "#                                          #"
    echo "############################################"
    read -p "Druecke Enter zum Neustarten..." dummy
    reboot
fi

# ============================================
# Image-Name mit Datum
# ============================================
IMAGE_NAME="fexobooth-image-$(date +%Y%m%d)"

log ""
log "Festplatte:  /dev/$TARGET_DISK"
log "Image-Name:  $IMAGE_NAME"
log ""

# Disk-Info dokumentieren (wichtig fuer spaetere Disk-Too-Small-Analyse)
log "Quell-Disk Details:"
lsblk -o NAME,SIZE,TYPE,FSTYPE,LABEL /dev/$TARGET_DISK 2>&1 | tee -a "$LOG_FILE"
log ""
log "Sektoren (Quell-Disk):"
blockdev --getsz /dev/$TARGET_DISK 2>&1 | tee -a "$LOG_FILE" || true
log "Groesse in Bytes (Quell-Disk):"
blockdev --getsize64 /dev/$TARGET_DISK 2>&1 | tee -a "$LOG_FILE" || true
log ""

log "Verfuegbarer Speicher fuer Image:"
df -h /home/partimag 2>&1 | tail -1 | tee -a "$LOG_FILE"
log ""

log_section "Das Image wird jetzt erstellt (ca. 15-30 Minuten)"

# ============================================
# Clonezilla savedisk ausfuehren
# ============================================
# -q2       = Partclone verwenden (schneller, zuverlaessiger)
# -batch    = Keine Bestaetigung (Auswahl erfolgt im GRUB-Menue)
# -j2       = Clone-Info im Image speichern
# -z5       = zstd Kompression (bestes Verhaeltnis/Geschwindigkeit)
# -i 4096   = Maximale Fragmentgroesse 4 GB
# -sfsck    = Dateisystem-Check ueberspringen (schneller)
# -senc     = Verschluesselung ueberspringen
# -p true   = ocs-sr beenden ohne eigenen Dialog (wir rebooten selbst)
/usr/sbin/ocs-sr \
    -q2 \
    -batch \
    -j2 \
    -z5 \
    -i 4096 \
    -sfsck \
    -senc \
    -p true \
    savedisk "$IMAGE_NAME" "$TARGET_DISK" 2>&1 | tee -a "$LOG_FILE"

OCS_EXIT=${PIPESTATUS[0]}
log ""
log "ocs-sr Exit-Code: $OCS_EXIT"
log ""

# ============================================
# Image-Verifikation (WICHTIG!)
# ============================================
# ocs-sr gibt Exit-Code 0 zurueck, auch wenn partclone fuer eine einzelne
# Partition fehlgeschlagen ist. Wir muessen daher ZUSAETZLICH pruefen:
#   1. Existiert das Image-Verzeichnis?
#   2. Steht in der parts-Datei welche Partitionen erwartet werden?
#   3. Existiert fuer JEDE erwartete Partition die *.ptcl-img.xz.aa Datei?
#   4. Hat das Log einen fatalen partclone-Fehler-Marker?
#
# Hintergrund: Wenn das NTFS dirty-bit gesetzt ist (Tablet wurde nicht sauber
# heruntergefahren), weigert sich partclone.ntfs zu klonen. ocs-sr macht
# trotzdem mit Hardware-Info-Files weiter und beendet sich mit Exit 0 — das
# Image ist dann aber unbrauchbar und wuerde beim Restore das Ziel bricken.
log_section "Image-Verifikation"

IMAGE_DIR="/home/partimag/$IMAGE_NAME"
VERIFY_OK=1
VERIFY_REASON=""

if [ ! -d "$IMAGE_DIR" ]; then
    VERIFY_OK=0
    VERIFY_REASON="Image-Verzeichnis nicht angelegt: $IMAGE_DIR"
elif [ ! -f "$IMAGE_DIR/parts" ]; then
    VERIFY_OK=0
    VERIFY_REASON="parts-Datei fehlt im Image-Verzeichnis"
else
    EXPECTED_PARTS=$(cat "$IMAGE_DIR/parts" 2>/dev/null)
    log "Erwartete Partitionen laut parts: $EXPECTED_PARTS"
    for PART in $EXPECTED_PARTS; do
        # Erste Image-Datei jeder Partition pruefen (z.B. mmcblk0p3.ntfs-ptcl-img.xz.aa)
        FOUND=$(ls "$IMAGE_DIR/${PART}."*-ptcl-img.xz.aa 2>/dev/null | head -1)
        if [ -z "$FOUND" ]; then
            VERIFY_OK=0
            VERIFY_REASON="Partition $PART fehlt im Image (keine ${PART}.*-ptcl-img.xz.aa Datei)"
            log "[FEHLT] $PART"
            break
        else
            FSIZE=$(stat -c%s "$FOUND" 2>/dev/null || echo 0)
            log "[OK] $PART ($(basename "$FOUND"), $((FSIZE/1024/1024)) MB)"
        fi
    done
fi

# Zusaetzlich Log auf bekannte fatale Marker pruefen
DIRTY_NTFS=0
if grep -qE "is scheduled for a check or it was shutdown uncleanly" "$LOG_FILE" 2>/dev/null; then
    DIRTY_NTFS=1
    VERIFY_OK=0
    VERIFY_REASON="NTFS-Volume dirty (Windows wurde nicht sauber heruntergefahren)"
elif grep -qE "Failed to save partition|Failed to use partclone" "$LOG_FILE" 2>/dev/null; then
    VERIFY_OK=0
    [ -z "$VERIFY_REASON" ] && VERIFY_REASON="partclone-Fehler im Log gefunden (siehe Log fuer Details)"
fi

if [ "$VERIFY_OK" -eq 0 ]; then
    CAPTURE_STATUS="FEHLER"
    ERROR_MESSAGE="$VERIFY_REASON"
    log ""
    log "[FEHLER] Image-Verifikation fehlgeschlagen!"
    log "         Grund: $VERIFY_REASON"
    log ""

    # Defektes Image umbenennen damit es nicht versehentlich beim Deploy genutzt wird
    if [ -d "$IMAGE_DIR" ]; then
        FAILED_DIR="${IMAGE_DIR}_FAILED_${TIMESTAMP}"
        mv "$IMAGE_DIR" "$FAILED_DIR" 2>/dev/null && \
            log "Defektes Image umbenannt zu: $(basename "$FAILED_DIR")" || \
            log "Konnte defektes Image nicht umbenennen — bitte manuell entfernen!"
    fi

    sync

    echo ""
    echo "############################################"
    echo "#                                          #"
    echo "#   FEHLER: Image NICHT vollstaendig!      #"
    echo "#                                          #"

    if [ "$DIRTY_NTFS" -eq 1 ]; then
        echo "#   Ursache: NTFS dirty bit gesetzt        #"
        echo "#                                          #"
        echo "#   LOESUNG:                               #"
        echo "#   1. Tablet ohne Stick neu starten       #"
        echo "#   2. Windows hochfahren, einmal anmelden #"
        echo "#   3. Sauber herunterfahren (Start-Menue) #"
        echo "#      NICHT Power-Knopf druecken!         #"
        echo "#   4. Capture nochmal starten             #"
    else
        echo "#   Grund: ${VERIFY_REASON:0:38}"
        echo "#                                          #"
        echo "#   Das halbe Image wurde umbenannt zu:    #"
        echo "#   ${IMAGE_NAME}_FAILED_<timestamp>"
        echo "#   und ist NICHT zum Restore geeignet.    #"
    fi

    echo "#                                          #"
    echo "#   Log-Datei:                              #"
    echo "#   FEXODATEN/capture-logs/                #"
    echo "#   capture-${TIMESTAMP}.log               "
    echo "#                                          #"
    echo "############################################"
    echo ""
    read -p "Druecke Enter zum Neustarten..." dummy
    reboot
fi

CAPTURE_STATUS="ERFOLG"

# Image-Groesse fuer Sanity-Check loggen
TOTAL_SIZE=$(du -sh "$IMAGE_DIR" 2>/dev/null | awk '{print $1}')
log "[OK] Image-Verifikation erfolgreich"
log "     Gesamtgroesse: $TOTAL_SIZE"
log ""

log_section "FERTIG! Image gespeichert als $IMAGE_NAME"
echo ""
echo "############################################"
echo "#                                          #"
echo "#   IMAGE ERFOLGREICH ERSTELLT!            #"
echo "#                                          #"
echo "#   Tablet startet in 5 Sekunden neu.      #"
echo "#                                          #"
echo "############################################"
echo ""
sleep 5
reboot
